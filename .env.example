# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/koolbase?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-long-random-string

# Email (Resend)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=Koolbase <noreply@yourdomain.com>

# Storage — Cloudflare R2
# S3_ENDPOINT=https://<accountID>.r2.cloudflarestorage.com
# R2_ACCOUNT_ID=your-account-id

# Storage — MinIO (self-hosted)
S3_ENDPOINT=http://minio:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=koolbase
R2_PUBLIC_URL=http://localhost:9000/koolbase

# App
APP_URL=http://localhost:3001
PORT=8080

# Internal API key (for snapshot rebuilds)
INTERNAL_API_KEY=change-me-to-a-random-string
